<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:CulinaryAssistant.Models"
             xmlns:viewmodels="clr-namespace:CulinaryAssistant.ViewModels"
             x:DataType="viewmodels:RecipeDetailsViewModel"
             x:Class="CulinaryAssistant.Views.RecipeDetailsPage"
             Title="Recipe Details">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <ActivityIndicator IsRunning="{Binding IsLoading}" 
                               IsVisible="{Binding IsLoading}" 
                               Color="Orange" 
                               HorizontalOptions="Center"/>

            <Image Source="{Binding Recipe.ImageUrl}" 
                   HeightRequest="250" 
                   Aspect="AspectFill"/>

            <Label Text="{Binding Recipe.Title}" 
                   FontSize="24" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center" 
                   HorizontalTextAlignment="Center"/>

            <Label Text="{Binding Recipe.Category}" 
                   FontSize="16" 
                   TextColor="Gray" 
                   HorizontalOptions="Center" />

            <Label Text="Ingredients:" FontSize="20" FontAttributes="Bold" Margin="0,15,0,5" />

            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Recipe.Ingredients}" Spacing="10">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="models:IngredientItem">
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="{Binding Name}" FontAttributes="Bold" />
                            <Label Text="-" TextColor="Gray" />
                            <Label Text="{Binding Measure}" />
                        </HorizontalStackLayout>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <Label Text="Instructions:" FontSize="20" FontAttributes="Bold" Margin="0,15,0,5" />

            <Label Text="{Binding Recipe.Instructions}" 
                   FontSize="16" 
                   LineBreakMode="WordWrap" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>