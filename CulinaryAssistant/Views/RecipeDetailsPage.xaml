            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="10" IsVisible="{Binding Recipe.Ingredient15, Converter={StaticResource NotEmptyConverter}}">
                <Label Text="{Binding Recipe.Ingredient15}" FontAttributes="Bold" />
                <Label Text="{Binding Recipe.Measure15}" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="10" IsVisible="{Binding Recipe.Ingredient16, Converter={StaticResource NotEmptyConverter}}">
                <Label Text="{Binding Recipe.Ingredient16}" FontAttributes="Bold" />
                <Label Text="{Binding Recipe.Measure16}" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="10" IsVisible="{Binding Recipe.Ingredient17, Converter={StaticResource NotEmptyConverter}}">
                <Label Text="{Binding Recipe.Ingredient17}" FontAttributes="Bold" />
                <Label Text="{Binding Recipe.Measure17}" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="10" IsVisible="{Binding Recipe.Ingredient18, Converter={StaticResource NotEmptyConverter}}">
                <Label Text="{Binding Recipe.Ingredient18}" FontAttributes="Bold" />
                <Label Text="{Binding Recipe.Measure18}" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="10" IsVisible="{Binding Recipe.Ingredient19, Converter={StaticResource NotEmptyConverter}}">
                <Label Text="{Binding Recipe.Ingredient19}" FontAttributes="Bold" />
                <Label Text="{Binding Recipe.Measure19}" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="10" IsVisible="{Binding Recipe.Ingredient20, Converter={StaticResource NotEmptyConverter}}">
                <Label Text="{Binding Recipe.Ingredient20}" FontAttributes="Bold" />
                <Label Text="{Binding Recipe.Measure20}" />
            </HorizontalStackLayout>

            <Label Text="Instructions:" FontSize="20" FontAttributes="Bold" Margin="0,15,0,5" />

            <Label Text="{Binding Recipe.Instructions}" 
                   FontSize="16" 
                   LineBreakMode="WordWrap" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>